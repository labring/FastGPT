# FastGPT enterprise internal deployment baseline.
# Copy this file to .env.enterprise and replace every <...> placeholder.

# Runtime image tags.
FASTGPT_IMAGE=ghcr.io/labring/fastgpt
FASTGPT_TAG=v4.14.22
FASTGPT_CODE_SANDBOX_IMAGE=ghcr.io/labring/fastgpt-code-sandbox
FASTGPT_CODE_SANDBOX_TAG=v4.14.22
FASTGPT_MCP_SERVER_IMAGE=ghcr.io/labring/fastgpt-mcp_server
FASTGPT_MCP_SERVER_TAG=v4.14.22
FASTGPT_PLUGIN_IMAGE=ghcr.io/labring/fastgpt-plugin
FASTGPT_PLUGIN_TAG=v0.6.2
FASTGPT_VOLUME_MANAGER_IMAGE=ghcr.io/labring/fastgpt-agent-volume-manager
FASTGPT_VOLUME_MANAGER_TAG=v0.1.2
AIPROXY_IMAGE=ghcr.io/labring/aiproxy
AIPROXY_TAG=v0.5.8
MONGO_IMAGE=mongo
MONGO_TAG=5.0.32
REDIS_IMAGE=redis
REDIS_TAG=7.2-alpine
MINIO_IMAGE=minio/minio
MINIO_TAG=RELEASE.2025-09-07T16-13-09Z
PGVECTOR_IMAGE=pgvector/pgvector
PGVECTOR_TAG=0.8.0-pg15

# Public URLs. Use HTTPS in production and do not use localhost.
FASTGPT_PORT=3000
FE_DOMAIN=https://fastgpt.internal.example.com
FILE_DOMAIN=https://fastgpt-files.internal.example.com
STORAGE_EXTERNAL_ENDPOINT=https://fastgpt-storage.internal.example.com
ALLOWED_ORIGINS=https://fastgpt.internal.example.com

# Security switches.
USE_IP_LIMIT=true
CHECK_INTERNAL_IP=true
TRUSTED_PROXY_ENABLE=true
TRUSTED_PROXY_IPS=10.0.0.10/32
PASSWORD_LOGIN_LOCK_SECONDS=300
PASSWORD_EXPIRED_MONTH=3
MAX_LOGIN_SESSION=3
MULTIPLE_DATA_TO_BASE64=true

# High-entropy application secrets. Generate with:
# openssl rand -base64 48
DEFAULT_ROOT_PSW=<replace-with-a-temporary-root-password>
TOKEN_KEY=<replace-with-random-secret>
FILE_TOKEN_KEY=<replace-with-random-secret>
AES256_SECRET_KEY=<replace-with-random-secret>
ROOT_KEY=<replace-with-random-secret>

# Service-to-service tokens.
PLUGIN_TOKEN=<replace-with-random-secret>
CODE_SANDBOX_TOKEN=<replace-with-random-secret>
AGENT_SANDBOX_PROXY_SECRET=<replace-with-random-secret>
AGENT_SANDBOX_VOLUME_MANAGER_TOKEN=<replace-with-random-secret>
AIPROXY_API_TOKEN=<replace-with-random-secret>

# Database and cache credentials.
DB_MAX_LINK=100
SYNC_INDEX=true
MONGO_INITDB_ROOT_USERNAME=fastgpt
MONGO_INITDB_ROOT_PASSWORD=<replace-with-random-secret>
MONGODB_URI=mongodb://fastgpt:<replace-with-url-encoded-password>@fastgpt-mongo:27017/fastgpt?authSource=admin
POSTGRES_USER=fastgpt
POSTGRES_PASSWORD=<replace-with-random-secret>
POSTGRES_DB=postgres
PG_URL=postgresql://fastgpt:<replace-with-url-encoded-password>@fastgpt-vector:5432/postgres
REDIS_PASSWORD=<replace-with-random-secret>
REDIS_URL=redis://default:<replace-with-url-encoded-password>@fastgpt-redis:6379
REDIS_MAX_CLIENTS=10000
REDIS_MAX_MEMORY=4gb

# AIProxy database credentials.
AIPROXY_POSTGRES_USER=aiproxy
AIPROXY_POSTGRES_PASSWORD=<replace-with-random-secret>
AIPROXY_POSTGRES_DB=aiproxy
AIPROXY_SQL_DSN=postgres://aiproxy:<replace-with-url-encoded-password>@fastgpt-aiproxy-pg:5432/aiproxy
AIPROXY_LOG_DETAIL_STORAGE_HOURS=1
AIPROXY_RETRY_TIMES=3
AIPROXY_BILLING_ENABLED=false
AIPROXY_DISABLE_MODEL_CONFIG=true

# Object storage.
STORAGE_VENDOR=minio
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=<replace-with-random-secret>
STORAGE_SECRET_ACCESS_KEY=<replace-with-random-secret>
STORAGE_PUBLIC_BUCKET=fastgpt-public
STORAGE_PRIVATE_BUCKET=fastgpt-private
STORAGE_S3_ENDPOINT=http://fastgpt-minio:9000
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_MAX_RETRIES=3
MINIO_ROOT_USER=<replace-with-random-secret>
MINIO_ROOT_PASSWORD=<replace-with-random-secret>

# Sandbox hardening.
AGENT_SANDBOX_PROVIDER=opensandbox
AGENT_SANDBOX_OPENSANDBOX_API_KEY=
AGENT_SANDBOX_IMAGE_REPO=ghcr.io/labring/fastgpt-agent-sandbox
AGENT_SANDBOX_IMAGE_TAG=v0.1.2
AGENT_SANDBOX_OPENSANDBOX_USE_SERVER_PROXY=true
AGENT_SANDBOX_ENABLE_VOLUME=true
AGENT_SANDBOX_PROXY_URL=wss://fastgpt-sandbox.internal.example.com
AGENT_SANDBOX_VOLUME_NAME_PREFIX=fastgpt-session
AGENT_SANDBOX_VOLUME_MANAGER_LOG_LEVEL=info
AGENT_SANDBOX_VOLUME_MANAGER_DOCKER_API_VERSION=v1.44
SANDBOX_MAX_TIMEOUT=60000
SANDBOX_MAX_MEMORY_MB=256
SANDBOX_POOL_SIZE=10
SANDBOX_CHECK_INTERNAL_IP=true
SANDBOX_REQUEST_MAX_COUNT=20
SANDBOX_REQUEST_TIMEOUT=30000
SANDBOX_REQUEST_MAX_RESPONSE_MB=5
SANDBOX_REQUEST_MAX_BODY_MB=2
SANDBOX_JS_ALLOWED_MODULES=lodash,dayjs,uuid,crypto-js,qs,url,querystring
SANDBOX_PYTHON_ALLOWED_MODULES=math,decimal,random,statistics,collections,itertools,functools,operator,string,re,json,csv,base64,hashlib,hmac,secrets,uuid,datetime,time

# Observability.
TZ=Asia/Taipei
LOG_ENABLE_CONSOLE=true
LOG_CONSOLE_LEVEL=info
LOG_ENABLE_OTEL=true
LOG_OTEL_LEVEL=info
LOG_OTEL_SERVICE_NAME=fastgpt
CODE_SANDBOX_LOG_SERVICE_NAME=fastgpt-code-sandbox
MCP_SERVER_LOG_SERVICE_NAME=fastgpt-mcp-server
PLUGIN_LOG_SERVICE_NAME=fastgpt-plugin
LOG_OTEL_URL=https://otel.internal.example.com/v1/logs
METRICS_ENABLE_OTEL=true
METRICS_OTEL_URL=https://otel.internal.example.com/v1/metrics
METRICS_OTEL_SERVICE_NAME=fastgpt
TRACING_ENABLE_OTEL=true
TRACING_OTEL_URL=https://otel.internal.example.com/v1/traces
TRACING_OTEL_SERVICE_NAME=fastgpt
