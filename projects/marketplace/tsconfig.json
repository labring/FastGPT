{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../../packages/**/*.ts",
    "../../packages/**/*.d.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "../../packages/**/vitest.config.ts",
    "../../packages/**/vitest.integration.config.ts",
    "../../packages/**/test/**"
  ]
}
