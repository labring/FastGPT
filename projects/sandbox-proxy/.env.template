# ===== Server =====
# Optional. Port the proxy listens on.
SANDBOX_PROXY_PORT=3006

# ===== Auth =====
# Shared HMAC secret with the FastGPT app (must match SANDBOX_PROXY_SECRET there)
SANDBOX_PROXY_SECRET=

# Internal HTTP base for callbacks to the FastGPT app (cs-password lookup, etc.).
# This URL is reached only by the proxy process — typically loopback or service-mesh.
SANDBOX_PROXY_APP_BASE_URL=http://localhost:3000

# ===== Logging =====
# Optional.
LOG_LEVEL=info
