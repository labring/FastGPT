// 已使用 json5 进行解析，会自动去掉注释，无需手动去除
{
  "feConfigs": {
    "lafEnv": "https://laf.dev", // laf环境。 https://laf.run （杭州阿里云） ,或者私有化的laf环境。如果使用 Laf openapi 功能，需要最新版的 laf 。
    "mcpServerProxyEndpoint": "", // mcp server 代理地址，例如： http://localhost:3005
    "show_publish_wecom": true
  },
  "systemEnv": {
    "datasetParseMaxProcess": 10, // 知识库文件解析最大线程数量
    "vectorMaxProcess": 10, // 向量处理线程数量
    "qaMaxProcess": 10, // 问答拆分线程数量
    "hypeMaxProcess": 5, // 索引增强线程数量
    "vlmMaxProcess": 10, // 图片理解模型最大处理进程
    "tokenWorkers": 30, // Token 计算线程保持数，会持续占用内存，不能设置太大。
    "hnswEfSearch": 100, // 向量搜索参数，仅对 PG 和 OB 生效。越大，搜索越精确，但是速度越慢。设置为100，有99%+精度。
    "hnswMaxScanTuples": 100000, // 向量搜索最大扫描数据量，仅对 PG生效。
    "assistantRetrievalLimit": 20, // Assistant场景：检索结果数量限制（默认：20）
    "assistantFinalResultLimit": 10, // Assistant场景：最终返回的检索结果数量限制（默认：10）
    "correctionSimilarityThreshold": 0.95, // Assistant场景：校正数据相似度阈值，命中后直接返回（默认：0.95）
    "faqSimilarityThreshold": 0.95, // Assistant场景：FAQ数据相似度阈值，命中后直接返回（默认：0.95）
    "customPdfParse": {
      "url": "", // 自定义 PDF 解析服务地址
      "key": "", // 自定义 PDF 解析服务密钥
      "timeout": 60, // 自定义 PDF 解析超时时间
      "doc2xKey": "", // doc2x 服务密钥
      "textinAppId": "", // 合合信息 Textin 服务 App ID
      "textinSecretCode": "", // 合合信息 Textin 服务 Secret Code
      "price": 0 // PDF 解析服务价格
    },
    "evalConfig": {
      "taskConcurrency": 3,
      "caseConcurrency": 10,
      "caseMaxRetry": 3,
      "caseResultThreshold": 0.8,
      "summaryConcurrency": 1,
      "dataQualityConcurrency": 2,
      "datasetDataSynthesizeConcurrency": 5,
      "datasetSmartGenerateConcurrency": 2,
      "maxStalledCount": 3
    },
    "trainConfig": {
      "taskConcurrency": 1,
      "dataGenerateConcurrency": 3,
      "maxStalledCount": 3
    },
    "hypeParams": {
      "similarityThreshold": 0.85, // 用于判断语义漂移, CosineSimilarity(candidateQuery,top1Doc),top1Doc!=tarDoc
      "maxDeltaScore": 0.15, // 用于判断语义漂移, Score(Top1Doc) - Score(tarDoc) 必须低于此值
      "minDeltaScore": 0.05, // 用于判断语义区分度,Score(tarDoc)- Score(nextDoc) 必须低于此值
      "expectRank": 3, // 目标文档排名必须高于此值
      "defaultScore": 0.8, // 对于低top1相似度的未检索目标的默认分数(表示候选具有良好的离散性/多样性)
      "topK": 20, // 召回的文档数量
      "rerank": false, // 是否使用重排序
      "min_rerank_threshold": 0.85 // 重排序最小阈值
    },
    "customTemplateImport": {
      "defaultActivateMode": "default", // 默认激活的模式
      "modes": [
        {
          "name": "default", // 模式名称
          "enabled": true, // 是否启用此模式
          "contentDetection": {
            // 内容探测规则（预留，用于根据内容自动选择模式）
            "rules": []
          },
          "enhanceConfig": {
            "autoIndexes": true, // 是否开启AI自动索引生成
            "small2bigIndexes": true, // 是否开启small2big索引
            "syntheticIndex": true, // 是否开启合成索引（默认开启）
            "hypeIndexes": false, // 是否开启超参数索引
            "hypeIndexPrompt": "", // 超参数索引的自定义prompt
            "small2bigConfig": {}, // small2big配置
            "autoIndexesPrompt": "", // 自动索引的自定义prompt
            "imageIndexPrompt": "" // 图片索引的自定义prompt
          }
        }
      ]
    },
    "customFileImport": {
      "defaultActivateMode": "default", // 默认激活的模式
      "modes": [
        {
          "name": "default", // 模式名称
          "enabled": true, // 是否启用此模式
          "fileTypes": ["txt", "md", "html", "pdf", "docx", "pptx", "xlsx", "csv"], // 适用的文件类型
          "contentDetection": {
            "rules": [] // 内容探测规则（预留）
          },
          "parseConfig": {
            "customPdfParse": true // PDF 增强解析（会根据系统配置自动调整）
          },
          "chunkConfig": {
            "trainingType": "chunk", // 训练类型：chunk 或 qa
            "chunkTriggerType": "minSize", // 分块触发类型
            "chunkTriggerMinSize": 1000, // 触发分块的最小长度
            "chunkSettingMode": "auto", // 分块设置模式
            "chunkSplitMode": "paragraph", // 分块切分模式
            "paragraphChunkAIMode": "forbid", // 段落分块AI模式
            "paragraphChunkDeep": 5, // 段落分块深度
            "paragraphChunkMinSize": 100, // 段落分块最小长度
            "chunkSize": 1000, // 分块大小
            "chunkSplitter": "", // 自定义分块分隔符
            "indexSize": 1024 // 索引大小
          },
          "enhanceConfig": {
            "dataEnhanceCollectionName": false, // 数据增强集合名称
            "imageIndex": true, // 图片自动索引（会根据VLM模型配置自动调整）
            "autoIndexes": true, // AI自动索引（会根据Agent模型配置自动调整）
            "hypeIndexes": false, // 超参数索引
            "indexPrefixTitle": false, // 索引前缀标题
            "small2bigIndexes": false, // small2big索引
            "syntheticIndex": true // 合成索引（会根据Agent模型配置自动调整）
          },
          "promptConfig": {
            "autoIndexesPrompt": "", // 自动索引prompt
            "hypeIndexPrompt": "", // 超参数索引prompt
            "imageIndexPrompt": "", // 图片索引prompt
            "qaPrompt": "" // QA模式prompt
          }
        }
      ]
    },
    "customLinkImport": {
      "defaultActivateMode": "default", // 默认激活的模式
      "modes": [
        {
          "name": "default", // 模式名称
          "enabled": true, // 是否启用此模式
          "contentDetection": {
            "rules": [] // 内容探测规则（预留）
          },
          "parseConfig": {
            "webPageSelector": "" // 网页选择器
          },
          "chunkConfig": {
            "trainingType": "chunk", // 训练类型
            "chunkTriggerType": "minSize", // 分块触发类型
            "chunkTriggerMinSize": 1000, // 触发分块的最小长度
            "chunkSettingMode": "auto", // 分块设置模式
            "chunkSplitMode": "paragraph", // 分块切分模式
            "chunkSize": 1000, // 分块大小
            "indexSize": 1024 // 索引大小
          },
          "enhanceConfig": {
            "autoIndexes": true, // AI自动索引（会根据Agent模型配置自动调整）
            "hypeIndexes": false, // 超参数索引
            "imageIndex": false // 图片索引（会根据VLM模型配置自动调整）
          },
          "promptConfig": {
            "autoIndexesPrompt": "", // 自动索引prompt
            "hypeIndexPrompt": "" // 超参数索引prompt
          }
        }
      ]
    },
    "enableStandaloneSummary": true, // 是否启用独立摘要生成（Pentomino SummaryEnhancer）
    "summaryMinLength": 500, // 独立摘要最小长度阈值（字符数），低于此长度不生成摘要，默认500（参考 Pentomino data_splitter_config.chunk_size）
    "datasetSqlResultLimit": 100 // 数据集SQL查询结果数量限制（默认：100）
  }
}