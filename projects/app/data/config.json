// 已使用 json5 进行解析，会自动去掉注释，无需手动去除
{
  "feConfigs": {
    "lafEnv": "https://laf.dev", // laf环境。 https://laf.run （杭州阿里云） ,或者私有化的laf环境。如果使用 Laf openapi 功能，需要最新版的 laf 。
    "mcpServerProxyEndpoint": "" // mcp server 代理地址，例如： http://localhost:3005
  },
  "systemEnv": {
    "vectorMaxProcess": 10, // 向量处理线程数量
    "qaMaxProcess": 10, // 问答拆分线程数量
    "hypeMaxProcess": 5, // 索引增强线程数量
    "vlmMaxProcess": 10, // 图片理解模型最大处理进程
    "tokenWorkers": 30, // Token 计算线程保持数，会持续占用内存，不能设置太大。
    "hnswEfSearch": 100, // 向量搜索参数，仅对 PG 和 OB 生效。越大，搜索越精确，但是速度越慢。设置为100，有99%+精度。
    "hnswMaxScanTuples": 100000, // 向量搜索最大扫描数据量，仅对 PG生效。
    "customPdfParse": {
      "url": "", // 自定义 PDF 解析服务地址
      "key": "", // 自定义 PDF 解析服务密钥
      "doc2xKey": "", // doc2x 服务密钥
      "price": 0 // PDF 解析服务价格
    },
    "evalConfig": {
      "taskConcurrency": 3,
      "caseConcurrency": 10,
      "caseMaxRetry": 3,
      "caseResultThreshold": 0.8,
      "summaryConcurrency": 1,
      "dataQualityConcurrency": 2,
      "datasetDataSynthesizeConcurrency": 5,
      "datasetSmartGenerateConcurrency": 2,
      "maxStalledCount": 3
    },
    "trainConfig": {
      "taskConcurrency": 1,
      "dataGenerateConcurrency": 3,
      "maxStalledCount": 3
    },
    "hypeParams": {
      "similarityThreshold": 0.85, // 用于判断语义漂移, CosineSimilarity(candidateQuery,top1Doc),top1Doc!=tarDoc
      "maxDeltaScore": 0.15, // 用于判断语义漂移, Score(Top1Doc) - Score(tarDoc) 必须低于此值
      "minDeltaScore": 0.05, // 用于判断语义区分度,Score(tarDoc)- Score(nextDoc) 必须低于此值
      "expectRank": 3, // 目标文档排名必须高于此值
      "defaultScore": 0.8, // 对于低top1相似度的未检索目标的默认分数(表示候选具有良好的离散性/多样性)
      "topK": 20, // 召回的文档数量
      "rerank": false, // 是否使用重排序
      "min_rerank_threshold": 0.85 // 重排序最小阈值
    }
  }
}