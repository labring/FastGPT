{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["../../test/*"],
      "@t3-oss/env-core": ["../../packages/service/node_modules/@t3-oss/env-core/dist/index.d.ts"],
      "@fastgpt/service/*": ["../../packages/service/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx",
    "../../packages/**/*.d.ts",
    "../../test/list.test.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "../../packages/**/*.test.ts", "../../packages/**/*.test.tsx", ".next", "dist", "coverage"]
}
