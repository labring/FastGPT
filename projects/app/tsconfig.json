{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "#fastgpt/app/test/*": ["./test/*"],
      "@test/*": ["../../test/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "../../packages/**/vitest.config.ts",
    "../../packages/**/vitest.integration.config.ts",
    "../../packages/**/test/**",
    ".next",
    "dist",
    "coverage"
  ]
}
