# diting-rag-ts Configuration
# 环境变量优先级: .env > config.yaml > 默认值
# 兼容 Python 版命名风格

# ===================
# LLM 配置
# ===================
# 主要 (同 Python 版 LLM_*)
LLM_BASE_URL=http://fastgpt-aiproxy.default:3000/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=Qwen3-Next-80B-A3B-Instruct-FP8

# ===================
# Embedding 配置
# ===================
EMBEDDING_BASE_URL=http://fastgpt-aiproxy.default:3000/v1
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=bge-m3

# ===================
# Reranker 配置 (可选)
# ===================
RERANKER_BASE_URL=http://fastgpt-aiproxy.default:3000/v1
RERANKER_API_KEY=sk-xxx
RERANKER_MODEL=bge-reranker-large
RERANKER_TOP_K=10

# ===================
# FastGPT 检索配置
# ===================
FASTGPT_API_BASE=https://10.57.2.100:19443/api
FASTGPT_API_KEY=

# ===================
# 向量数据库
# ===================
VECTOR_DB=pgvector  # pgvector | milvus

# PGVector
PG_URL=postgresql://postgres:password@localhost:5432/postgres
# 或分字段配置:
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=postgres
# PG_USER=postgres
# PG_PASSWORD=password

# Milvus (如果 VECTOR_DB=milvus)
# MILVUS_ADDRESS=localhost:19530
# MILVUS_TOKEN=
# MILVUS_DATABASE=default

# ===================
# 全文检索数据库 (Full-text DB)
# ===================
FULLTEXT_DB=mongodb  # mongodb | opensearch

# MongoDB (if FULLTEXT_DB=mongodb)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=fastgpt

# OpenSearch (if FULLTEXT_DB=opensearch, 预留)
# OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_INDEX=my_index

# ===================
# Agent 配置
# ===================
SEARCH_MODE=mixedRecall  # embedding | fullTextRecall | mixedRecall
MAX_SEARCH_ROUNDS=5
MAX_TOOL_CALLS=10
EMBEDDING_WEIGHT=0.5
SIMILARITY=0.0

# ===================
# 服务配置
# ===================
PORT=3123
HOST=0.0.0.0