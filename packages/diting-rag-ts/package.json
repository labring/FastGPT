{
  "name": "diting-rag-ts",
  "version": "0.1.0",
  "description": "Agentic RAG implementation in TypeScript, based on langgraph-js",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./testing": {
      "import": "./src/testing/index.ts",
      "types": "./src/testing/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch bin/server.ts",
    "start": "tsx bin/server.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "compat": "tsx test/model-compat.test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/openai": "^3.0.52",
    "@hono/node-server": "^1.13.0",
    "@langchain/langgraph": "^0.2.0",
    "@zilliz/milvus2-sdk-node": "2.6.9",
    "ai": "^6.0.158",
    "commander": "^11.1.0",
    "dotenv": "^16.3.0",
    "eld": "2.0.3",
    "hono": "^4.0.0",
    "jieba-wasm": "^2.2.0",
    "js-yaml": "^4.1.0",
    "mongodb": "^6.3.0",
    "pg": "^8.11.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "ai": "^4.3.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
