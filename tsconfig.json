{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@fastgpt/*": ["packages/*"],
      "@test": ["test/*"],
      "diting-rag-ts": ["packages/diting-rag-ts/src/index.ts"],
      "diting-rag-ts/*": ["packages/diting-rag-ts/src/*"]
    }
  },
  "exclude": ["node_modules", "**/node_modules", "**/node_modules/**"]
}
