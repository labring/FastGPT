            "content": "#!/bin/sh\n# Sync Agent HTTP 请求处理器\n# 由 socat 每次连接时 fork 执行\n# 支持：GET /health、POST /sync\n\nSTATE_DIR=\"${STATE_DIR:-/tmp/sync-state}\"\n\n# 读取请求行\nread -r REQUEST_LINE\nMETHOD=$(echo \"${REQUEST_LINE}\" | awk '{print $1}' | tr -d '\\r')\nPATH_REQ=$(echo \"${REQUEST_LINE}\" | awk '{print $2}' | tr -d '\\r')\n\n# 排空请求头（读到空行为止）\nwhile IFS= read -r line; do\n  line=$(echo \"${line}\" | tr -d '\\r')\n  [ -z \"${line}\" ] && break\ndone\n\n# 读取状态文件\nLAST_SYNC=$(cat \"${STATE_DIR}/last_sync\" 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)\nPENDING=$(cat \"${STATE_DIR}/pending_count\" 2>/dev/null || echo \"0\")\n\nsend_json() {\n  BODY=\"$1\"\n  CODE=\"$2\"\n  LEN=${#BODY}\n  printf \"HTTP/1.1 %s\\r\\nContent-Type: application/json\\r\\nContent-Length: %d\\r\\nConnection: close\\r\\n\\r\\n%s\" \\\n    \"${CODE}\" \"${LEN}\" \"${BODY}\"\n}\n\ncase \"${PATH_REQ}\" in\n  /health)\n    BODY=\"{\\\"status\\\":\\\"healthy\\\",\\\"lastSync\\\":\\\"${LAST_SYNC}\\\",\\\"pendingCount\\\":${PENDING}}\"\n    send_json \"${BODY}\" \"200 OK\"\n    ;;\n  /sync)\n    if [ \"${METHOD}\" = \"POST\" ]; then\n      # 写入触发文件，sync.sh 周期检查时会立即执行一次全量同步\n      touch \"${STATE_DIR}/trigger\"\n      send_json '{\"success\":true}' \"200 OK\"\n    else\n      send_json '{\"error\":\"Method Not Allowed\"}' \"405 Method Not Allowed\"\n    fi\n    ;;\n  *)\n    printf \"HTTP/1.1 404 Not Found\\r\\nContent-Length: 0\\r\\nConnection: close\\r\\n\\r\\n\"\n    ;;\nesac\n",
