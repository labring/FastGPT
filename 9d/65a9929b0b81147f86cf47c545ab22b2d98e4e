st healthy = await sandbox.ping();\n    console.log(`Health check (ping): ${healthy ? 'HEALTHY' : 'UNHEALTHY'}`);\n\n    // Get resource metrics\n    const metrics = await sandbox.getMetrics();\n    console.log(`Resource Metrics:`);\n    console.log(`  CPU Count: ${metrics.cpuCount}`);\n    console.log(`  CPU Usage: ${metrics.cpuUsedPercentage.toFixed(2)}%`);\n    console.log(`  Memory: ${metrics.memoryUsedMiB}/${metrics.memoryTotalMiB} MiB`);\n    console.log(`  Timestamp: ${new Date(metrics.timestamp).toISOString()}\\n`);\n\n    // ============ LIFECYCLE STATE EXAMPLES ============\n    console.log('--- Lifecycle State Changes ---\\n');\n\n    // Check if pause/resume is supported (not supported on Kubernetes runtime)\n    if (sandbox.capabilities.supportsPauseResume) {\n      // Pause the sandbox\n      console.log('Pausing sandbox...');\n      await sandbox.pause();\n      console.log('Sandbox paused');\n\n      // Resume the sandbox\n      console.log('Resuming sandbox...');\n      await sandbox.resume();\n      console.log('Sandbox resumed\\n');\n    } else {\n      console.log('Pause/Resume not supported by this provider/runtime\\n');\n    }\n\n    // Stop (graceful shutdown)\n    console.log('Stopping sandbox (graceful)...');\n    await sandbox.stop();\n    console.log('Sandbox stopped\\n');\n\n    if (sandbox.runtime !== 'kubernetes') {\n      // Cleanup - delete sandbox\n      console.log('Deleting sandbox...');\n      await sandbox.delete();\n      console.log('Sandbox deleted');\n    }\n  } finally {\n    await sandbox.close();\n    console.log('Connection closed');\n  }\n}\n\nasync function exampleWithMinimalProvider() {\n  console.log('\\n=== Minimal Provider Example ===\\n');\n\n  // Create a minimal provider adapter\n  // This could be any command-based sandbox (SSH, custom API, etc.)\n  const adapter = new MinimalProviderAdapter();\n\n  console.log(`Provider: ${adapter.provider}`);\n  console.log(`Native filesystem: ${adapter.capabilities.nativeFile