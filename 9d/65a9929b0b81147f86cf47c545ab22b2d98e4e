y 1 hour)\n    await sandbox.renewExpiration(3600);\n    console.log('Sandbox expiration renewed by 1 hour\\n');\n\n    // ============ EXECUTION EXAMPLES ============\n    console.log('--- Command Execution ---\\n');\n\n    // Basic command execution\n    const version = await sandbox.execute('nginx -v');\n    console.log(`Nginx version: ${version.stdout || version.stderr}`);\n\n    const files = await sandbox.execute('ls -la /');\n    console.log(`Root directory:\\n${files.stdout}\\n`);\n\n    // Streaming execution with real-time output\n    console.log('Streaming execution example:');\n    await sandbox.executeStream('for i in 1 2 3; do echo \"Line $i\"; sleep 0.5; done', {\n      onStdout: (msg) => console.log(`  [stdout] ${msg.text}`),\n      onStderr: (msg) => console.log(`  [stderr] ${msg.text}`),\n      onComplete: (result) => console.log(`  [done] Exit code: ${result.exitCode}\\n`),\n    });\n\n    // Background execution\n    console.log('Background execution example:');\n    const bgExecution = await sandbox.executeBackground('sleep 10 && echo \"Background task done\"');\n    console.log(`  Started background session: ${bgExecution.sessionId}`);\n\n    // Check if sandbox is still healthy\n    const isHealthy = await sandbox.ping();\n    console.log(`  Sandbox healthy: ${isHealthy}`);\n\n    // Kill the background execution\n    await bgExecution.kill();\n    console.log('  Background execution killed\\n');\n\n    // ============ FILESYSTEM EXAMPLES ============\n    console.log('--- Filesystem Operations ---\\n');\n\n    // Create directories\n    await sandbox.createDirectories(['/app/src', '/app/logs', '/app/data']);\n    console.log('Created directories: /app/src, /app/logs, /app/data');\n\n    // Write multiple files\n    await sandbox.writeFiles([\n      {\n        path: '/app/src/index.js',\n        data: `console.log('Hello from sandbox!');\nconsole.log('Current time:', new Date().toISOString());`,\n      },\n      {\n        path: '/app/package.