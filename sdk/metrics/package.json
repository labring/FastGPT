{
  "name": "@fastgpt-sdk/metrics",
  "private": false,
  "version": "0.1.0",
  "description": "FastGPT SDK for metrics",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "metrics",
    "opentelemetry"
  ],
  "author": "FastGPT",
  "repository": {
    "type": "git",
    "url": "https://github.com/labring/FastGPT.git",
    "directory": "FastGPT/sdk/metrics"
  },
  "homepage": "https://github.com/labring/FastGPT",
  "bugs": {
